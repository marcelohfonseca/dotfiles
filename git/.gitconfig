[user]
	name = Marcelo Henrique Fonseca
	email = dev@marcelofonseca.me
	signingkey = ~/.ssh/id_ed25519_sk.pub
[init]
	defaultBranch = main
[pull]
	ff = only
	default = simple
	followTags = true
[commit]
	gpgsign = true
[merge]
    verifySignatures = false
[tag]
    gpgsign = true
[log]
    showSignature = true
[lfs]
    filter = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
[credential]
        helper = !gh auth git-credential
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
